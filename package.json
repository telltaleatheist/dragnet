{
  "name": "dragnet",
  "version": "1.0.0",
  "description": "Dragnet - Local content discovery and scoring tool",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "postinstall": "npm run install:backend",
    "install:all": "npm install && npm run install:backend && npm run install:frontend",
    "install:backend": "cd backend && npm install",
    "install:frontend": "cd frontend && npm install",
    "rebuild:native": "npx electron-rebuild -f -w better-sqlite3 --module-dir backend",
    "build:all": "npm run build:shared && npm run build:backend && npm run rebuild:native && npm run build:frontend && npm run build:electron && npm run build:preload",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "build:frontend:dev": "cd frontend && npx ng build --configuration=development",
    "build:electron": "tsc -p electron/tsconfig.electron.json",
    "build:preload": "tsc -p electron/tsconfig.preload.json",
    "build:shared": "tsc -p shared",
    "build:fast": "npm run build:shared && npm run build:backend && npm run build:frontend:dev && npm run build:electron && npm run build:preload",
    "electron:dev": "npm run build:all && cross-env NODE_ENV=development electron .",
    "dev": "npm run electron:dev",
    "dev:fast": "npm run build:fast && cross-env NODE_ENV=development electron .",
    "dev:backend": "cd backend && npm run start:dev",
    "dev:frontend": "cd frontend && npm run build -- --watch",
    "clean": "rimraf dist-electron",
    "clean:all": "npm run clean && rimraf dist",
    "package:mac": "npm run clean && npm run build:all && electron-builder --mac --arm64 --x64 --publish never",
    "package:mac-arm64": "npm run clean && npm run build:all && electron-builder --mac --arm64 --publish never",
    "package:mac-x64": "npm run clean && npm run build:all && electron-builder --mac --x64 --publish never",
    "package:mac:fast": "npm run build:all && electron-builder --mac --arm64 --publish never",
    "package:win-x64": "npm run clean && npm run build:all && electron-builder --win --x64 --publish never",
    "package:linux": "npm run clean && npm run build:all && electron-builder --linux --x64 --publish never"
  },
  "keywords": [
    "content-discovery",
    "scraping",
    "nestjs",
    "angular",
    "electron",
    "typescript"
  ],
  "author": "Owen Morgan",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.3",
    "cross-env": "^7.0.3",
    "electron": "^33.4.11",
    "electron-builder": "^24.13.3",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "better-sqlite3": "^12.4.1",
    "electron-log": "^5.3.3",
    "electron-store": "^8.2.0",
    "proper-lockfile": "^4.1.2",
    "reflect-metadata": "^0.1.13"
  },
  "build": {
    "appId": "com.owenmorgan.dragnet",
    "productName": "Dragnet",
    "icon": "assets/icon",
    "asar": true,
    "compression": "normal",
    "directories": {
      "output": "dist-electron"
    },
    "extraResources": [
      {
        "from": "backend/node_modules",
        "to": "backend/node_modules",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "backend/dist",
        "to": "backend/dist"
      },
      {
        "from": "dist-electron/shared",
        "to": "dist-electron/shared",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "frontend/dist/frontend/browser",
        "to": "frontend/dist/frontend/browser"
      }
    ],
    "files": [
      "dist-electron/electron/**/*",
      "dist-electron/shared/**/*",
      "!dist-electron/**/*.map",
      "!backend/**",
      "!frontend/**",
      "node_modules/**/*",
      "!**/node_modules/**/test/**",
      "!**/node_modules/**/tests/**",
      "!**/node_modules/**/*.md",
      "!**/node_modules/**/*.d.ts",
      "!**/node_modules/**/*.map",
      "!**/node_modules/**/LICENSE*",
      "!**/node_modules/**/docs/**"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Utility"
    },
    "dmg": {
      "format": "ULFO"
    }
  }
}
